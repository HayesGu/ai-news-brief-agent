# Copy this file to .env for local development.
# Do not commit real secrets or API keys.

APP_ENV=development
LOG_LEVEL=INFO

# LLM provider configuration.
# DeepSeek is the default provider and uses an OpenAI-compatible API.
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Optional Gemini-compatible provider setting.
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash

# Local paths used by ingestion, storage, and reporting workflows.
PROFILE_CONFIG_PATH=config/profile.yaml
PROMPTS_DIR=prompts
DATA_DIR=data

# Optional: copy generated daily Markdown reports into an Obsidian daily notes folder.
OBSIDIAN_DAILY_KB_SYNC_ENABLED=false
OBSIDIAN_DAILY_KB_PATH=D:\path\to\your\obsidian\vault\01 Daily
